{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/simple-portfolio.html"
    }
  ],
  "env": {
    "MONGODB_URI": "mongodb://localhost:27017/portfolio"
  }
}
